<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.telephony"
        android:required="false" />

    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.SEND_SMS" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"/>
    <uses-permission android:name="android.permission.CALL_PHONE" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.FLASHLIGHT" />
    <uses-permission android:name="android.permission.VIBRATE" />

    <application
        android:name=".MyApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/appicon"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MyApp"
        tools:targetApi="31">
        
        <!-- Google Maps API Key -->
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="@string/google_maps_api_key" />
        <activity
            android:name=".LoginActivity"
            android:exported="true"
            android:theme="@style/Theme.MyApp">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        
        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:theme="@style/Theme.App.Starting" />
            
        <activity
            android:name=".RegistrationActivity"
            android:exported="false"
            android:theme="@style/Theme.MyApp" />
        <activity android:name=".SosActivity" />
        <activity android:name=".EmergencyHelplineActivity" />
        <activity android:name=".SirenActivity"
            android:exported="false"
            android:theme="@style/Theme.MyApp" />
        <activity android:name=".ExploreLifesaveActivity"
            android:exported="false"
            android:theme="@style/Theme.MyApp" />
        <activity android:name=".CameraDetectorActivity"
            android:exported="false"
            android:theme="@style/Theme.MyApp" />
        <activity android:name=".EditProfileActivity"
            android:exported="false"
            android:theme="@style/Theme.MyApp" />
        <activity android:name=".ForgotPasswordActivity"
            android:exported="false"
            android:theme="@style/Theme.MyApp" />
    </application>

</manifest>