<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Pressed state -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/emergency_red_dark" />
            <corners android:radius="16dp" />
            <stroke android:width="2dp" android:color="@color/white" />
        </shape>
    </item>
    
    <!-- Focused state -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/emergency_red" />
            <corners android:radius="16dp" />
            <stroke android:width="3dp" android:color="@color/caution_yellow" />
        </shape>
    </item>
    
    <!-- Normal state -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/emergency_red" />
            <corners android:radius="16dp" />
            <stroke android:width="1dp" android:color="@color/emergency_red_dark" />
        </shape>
    </item>
</selector>
