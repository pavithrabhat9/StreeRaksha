<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_secondary"
    tools:context=".MainActivity">

    <!-- Single fragment container for all tabs (Home/Tips/Location/Profile) -->
    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="56dp" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/background_primary"
        android:elevation="2dp"
        style="@style/Widget.MyApp.BottomNavigationView"
        app:menu="@menu/bottom_nav_menu"
        app:itemIconSize="24dp"
        app:itemRippleColor="@android:color/transparent"
        app:itemTextAppearanceActive="@style/TextAppearance.MyApp.BottomNavigationView.Active"
        app:itemTextAppearanceInactive="@style/TextAppearance.MyApp.BottomNavigationView"
        app:itemBackground="@drawable/nav_item_background"
        app:itemActiveIndicatorStyle="@color/trust_blue"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
