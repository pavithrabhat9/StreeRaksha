<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_secondary"
    tools:context=".MainActivity">

    <!-- Modern Header Section -->
    <LinearLayout
        android:id="@+id/header_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface_secondary"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="@string/app_name"
            android:textColor="@color/electric_blue"
            android:textSize="30sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

        </LinearLayout>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="70dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="80dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="0dp"
            android:paddingBottom="18dp">

            <!-- Emergency SOS Section -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_sos_alert"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/surface_primary">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="22dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_marginEnd="16dp"
                            android:background="@drawable/alert2" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="4dp"
                                android:text="Emergency SOS"
                                android:textColor="@color/Onyx"
                                android:textSize="24sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tap to send instant alerts"
                                android:textColor="@color/text_secondary"
                                android:textSize="14sp" />
                        </LinearLayout>

                    </LinearLayout>

                    <!-- Emergency Button (Always Visible) -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_activate_emergency"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="ACTIVATE EMERGENCY"
                        android:textAllCaps="true"
                        android:textColor="@android:color/white"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:paddingVertical="12dp"
                        android:icon="@drawable/ic_alert"
                        android:backgroundTint="@color/red_primary"
                        app:cornerRadius="8dp"
                        app:rippleColor="@color/red_ripple"
                        style="@style/Widget.MaterialComponents.Button" />




                    <!-- Contacts Status (Below Button) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingTop="4dp">

                        <!-- Configured State -->
                        <TextView
                            android:id="@+id/tv_contacts_configured"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:background="@color/white"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="8dp"
                            android:text="✓ Emergency contacts configured"
                            android:textColor="@color/text_success_high_contrast"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:visibility="gone"
                            android:clickable="false"
                            android:focusable="false"
                            android:focusableInTouchMode="false" />

                        <!-- Not Configured State -->
                        <TextView
                            android:id="@+id/tv_contacts_not_configured"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:background="@color/white"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="8dp"
                            android:text="✗ Emergency contacts not configured"
                            android:textColor="@color/emergency_red_dark"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:visibility="visible"
                            android:clickable="false"
                            android:focusable="false"
                            android:focusableInTouchMode="false" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Safety Tools Section -->

            <!-- Modern Tools Grid -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:text="Safety Tools"
                android:textColor="@color/Onyx"
                android:textSize="20sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="24dp">

                <!-- Emergency Tools Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2"
                    android:layout_marginBottom="16dp">

                    <!-- Camera Detector -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/card_camera_detector"
                        android:layout_width="0dp"
                        android:layout_height="140dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:foreground="?android:attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/safety_accent">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="16dp">

                            <ImageView
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:src="@drawable/ic_hidden"
                                android:layout_marginBottom="8dp"
                                android:scaleType="fitCenter"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:text="Camera Detector"
                                android:textColor="@color/safety_primary"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:maxLines="1"
                                android:ellipsize="end" />
                                
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:text="Detect hidden cameras"
                                android:textColor="@color/grey_dark"
                                android:textSize="12sp"
                                android:maxLines="2"
                                android:ellipsize="end"
                                android:lineSpacingExtra="1dp"
                                android:paddingTop="2dp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Emergency Siren -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/card_siren"
                        android:layout_width="0dp"
                        android:layout_height="140dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:foreground="?android:attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/emergency_accent">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="16dp">

                            <ImageView
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:src="@drawable/ic_siren"
                                android:layout_marginBottom="8dp"
                                android:scaleType="fitCenter"/>

                            <TextView
                                android:id="@+id/siren_title"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Siren"
                                android:textColor="@color/emergency_primary"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:gravity="center"
                                android:maxLines="1"
                                android:ellipsize="end"
                                android:lineSpacingExtra="1dp" />
                                
                            <TextView
                                android:id="@+id/siren_description"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:text="Play emergency alarm"
                                android:textColor="@color/grey_dark"
                                android:textSize="12sp"
                                android:maxLines="2"
                                android:ellipsize="end"
                                android:lineSpacingExtra="1dp"
                                android:paddingTop="2dp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <!-- Support Tools Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <!-- Emergency Helpline -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/card_emergency_helpline"
                        android:layout_width="0dp"
                        android:layout_height="140dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:foreground="?android:attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/location_accent">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="16dp">

                            <View
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@drawable/ic_helpline"
                                android:layout_marginBottom="8dp"
                                android:scaleType="fitCenter"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Helpline"
                                android:textColor="@color/location_primary"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:gravity="center"
                                android:maxLines="1"
                                android:ellipsize="end"
                                android:lineSpacingExtra="1dp" />
                                
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:text="Connect to support"
                                android:textColor="@color/grey_dark"
                                android:textSize="12sp"
                                android:maxLines="2"
                                android:ellipsize="end"
                                android:lineSpacingExtra="1dp"
                                android:paddingTop="2dp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Manage Contacts -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/card_contacts"
                        android:layout_width="0dp"
                        android:layout_height="140dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:foreground="?android:attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#EFE6FD">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="16dp">

                            <View
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@drawable/ic_add_contacts"
                                android:layout_marginBottom="8dp"
                                android:scaleType="fitCenter"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Contacts"
                                android:textColor="@color/accent_purple"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:gravity="center"
                                android:maxLines="1"
                                android:ellipsize="end"
                                android:lineSpacingExtra="1dp" />
                                
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:text="Edit emergency list"
                                android:textColor="@color/grey_dark"
                                android:textSize="12sp"
                                android:maxLines="2"
                                android:ellipsize="end"
                                android:lineSpacingExtra="1dp"
                                android:paddingTop="2dp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>
            </LinearLayout>

            <!-- Quick Access Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="16dp"
                android:text="Quick Access"
                android:textColor="@color/Onyx"
                android:textSize="20sp"
                android:textStyle="bold" />

            <!-- Modern Quick Access Grid -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="4"
                android:layout_marginBottom="24dp">

                <!-- Police Card -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/card_police"
                        android:layout_width="match_parent"
                        android:layout_height="65dp"
                        android:foreground="?android:attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/surface_primary">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical">

                            <View
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="@drawable/ic_police"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:paddingTop="8dp"
                        android:text="Police Stations"
                        android:textColor="@color/Onyx"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Hospital Card -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginHorizontal="4dp">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/card_hospital"
                        android:layout_width="match_parent"
                        android:layout_height="65dp"
                        android:foreground="?android:attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/surface_primary">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical">

                            <View
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="@drawable/ic_hospital" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:paddingTop="8dp"
                        android:text="Hospitals"
                        android:textColor="@color/Onyx"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Fire Station Card -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginHorizontal="4dp">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/card_pharmacy"
                        android:layout_width="match_parent"
                        android:layout_height="65dp"
                        android:foreground="?android:attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/surface_primary">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical">

                            <View
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="@drawable/ic_pharmacy"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:paddingTop="8dp"
                        android:text="Pharmacies"
                        android:textColor="@color/Onyx"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Women's Helpline Card -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/card_women_shelter"
                        android:layout_width="match_parent"
                        android:layout_height="65dp"
                        android:foreground="?android:attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/surface_primary">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical">

                            <View
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="@drawable/ic_shelter" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:gravity="center"
                        android:maxLines="2"
                        android:paddingTop="8dp"
                        android:text="Women's Shelter"
                        android:textColor="@color/Onyx"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/surface_primary"
        android:elevation="2dp"
        style="@style/Widget.MyApp.BottomNavigationView"
        app:menu="@menu/bottom_nav_menu"
        app:itemIconSize="24dp"
        app:itemRippleColor="@android:color/transparent"
        app:itemTextAppearanceActive="@style/TextAppearance.MyApp.BottomNavigationView.Active"
        app:itemTextAppearanceInactive="@style/TextAppearance.MyApp.BottomNavigationView"
        app:itemBackground="@drawable/nav_item_background" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
