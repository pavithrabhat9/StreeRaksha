<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_secondary"
    android:fillViewport="true"
    tools:context=".TermsAndConditionsActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Toolbar -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/surface_primary"
            android:elevation="4dp"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:title="Terms and Conditions"
            app:titleTextColor="@color/text_primary" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

        <!-- Header Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/surface_primary">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="12dp"
                    android:src="@drawable/ic_terms"
                    app:tint="@color/accent_pink" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Terms and Conditions"
                    android:textColor="@color/text_primary"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:text="StreeRaksha Safety App"
                    android:textColor="@color/text_secondary"
                    android:textSize="16sp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Terms Content -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/surface_primary">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:text="Last Updated: January 2024"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:textStyle="italic" />

                <!-- Section 1 -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="1. Acceptance of Terms"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:text="By downloading, installing, or using the StreeRaksha mobile application, you agree to be bound by these Terms and Conditions. If you do not agree to these terms, please do not use our application."
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp" />

                <!-- Section 2 -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="2. Description of Service"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:text="StreeRaksha is a safety and emergency response application designed to help users in emergency situations. The app provides features including:\n\n• Emergency SOS alerts\n• Location sharing with emergency contacts\n• Hidden camera detection\n• Emergency contact management\n• Siren functionality\n• Nearby emergency services location\n\nThese features are intended for genuine emergency situations only."
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp" />

                <!-- Section 3 -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="3. User Responsibilities"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:text="As a user of StreeRaksha, you agree to:\n\n• Use the app responsibly and only in genuine emergency situations\n• Provide accurate information during registration\n• Keep your emergency contacts updated\n• Not misuse emergency features for non-emergency purposes\n• Respect the privacy of other users\n• Comply with all applicable laws and regulations\n• Report any technical issues or security concerns promptly"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp" />

                <!-- Section 4 -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="4. Privacy and Data Protection"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:text="We are committed to protecting your privacy and personal information. Our Privacy Policy explains how we collect, use, and protect your data. Key points include:\n\n• Location data is only shared with your designated emergency contacts\n• Personal information is encrypted and stored securely\n• We do not sell or share your data with third parties\n• You can request data deletion at any time\n• Emergency alerts are sent only to contacts you have explicitly authorized"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp" />

                <!-- Section 5 -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="5. Emergency Services Disclaimer"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:text="IMPORTANT: StreeRaksha is not a replacement for emergency services. In case of a real emergency:\n\n• Always call your local emergency number (911, 112, etc.)\n• The app is designed to supplement, not replace, official emergency services\n• We cannot guarantee immediate response to SOS alerts\n• Location accuracy depends on device GPS and network conditions\n• Emergency contacts should be informed about their role and responsibilities"
                    android:textColor="@color/emergency_red"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:lineSpacingExtra="4dp" />

                <!-- Section 6 -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="6. Limitation of Liability"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:text="To the maximum extent permitted by law, StreeRaksha and its developers:\n\n• Are not liable for any damages resulting from app use\n• Do not guarantee 100% accuracy of location services\n• Are not responsible for network connectivity issues\n• Cannot be held liable for misuse of emergency features\n• Provide the app 'as is' without warranties\n• Are not responsible for third-party service availability"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp" />

                <!-- Section 7 -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="7. Prohibited Uses"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:text="You may not use StreeRaksha for:\n\n• False emergency alerts or pranks\n• Harassment or stalking\n• Any illegal activities\n• Commercial purposes without permission\n• Attempting to hack or reverse engineer the app\n• Sharing inappropriate content\n• Impersonating emergency services"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp" />

                <!-- Section 8 -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="8. Account Termination"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:text="We reserve the right to:\n\n• Suspend or terminate accounts for violations\n• Remove inappropriate content\n• Update terms with notice\n• Discontinue service with reasonable notice\n• Block users who misuse emergency features\n\nYou may delete your account at any time through the app settings."
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp" />

                <!-- Section 9 -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="9. Updates and Changes"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:text="We may update these Terms and Conditions from time to time. Users will be notified of significant changes through:\n\n• In-app notifications\n• Email notifications\n• App store update descriptions\n\nContinued use of the app after changes constitutes acceptance of new terms."
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp" />

                <!-- Section 10 -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="10. Contact Information"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:text="For questions about these Terms and Conditions, please contact us:\n\n• Email: legal@streeraksha.com\n• Support: support@streeraksha.com\n• Phone: +1-800-HELP-911\n• Address: StreeRaksha Legal Department, Safety Tech Inc., 123 Safety Street, Secure City, SC 12345"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp" />

                <!-- Footer -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center"
                    android:text="By using StreeRaksha, you acknowledge that you have read, understood, and agree to be bound by these Terms and Conditions."
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
